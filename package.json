{
  "name": "ekspertbistand",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter ./frontend/client dev\" \"pnpm --filter ./frontend/server dev\"",
    "dev:saksbehandling": "pnpm --filter ./frontend/saksbehandling dev",
    "serve:saksbehandling": "pnpm --filter ./frontend/saksbehandling build && pnpm --filter ./frontend/saksbehandling-server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter ./frontend/client lint && pnpm --filter ./frontend/saksbehandling lint && pnpm --filter ./frontend/server lint && pnpm --filter ./frontend/saksbehandling-server lint",
    "lint:fix": "pnpm --filter ./frontend/client lint:fix && pnpm --filter ./frontend/saksbehandling lint:fix && pnpm --filter ./frontend/server lint:fix && pnpm --filter ./frontend/saksbehandling-server lint:fix",
    "format": "prettier --check frontend",
    "format:fix": "prettier --write frontend",
    "test": "pnpm --filter ./frontend/client test:run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "frontend/**/*.{json,md,css,scss}": [
      "prettier --write"
    ]
  }
}
